// Generic Collections
    - A Generic Collection is a type of collection in C# that can store a specific data type defined at the time of creating the collection
        - List<int> number = new List<int>();
        - List<string> letter = new List<string>()

    List<T>
    Dictionary<TKey, TValue>
    Stack<T>
    Queue<T>
    HashSet<T>
    SortedList<TKey, TValue>
    LinkedList<T>

// Queue
    - First in First out (FIFO)
        - Enqueue() - To add data in Queue.
        - Dequeue() - To remove data in Queue.
        - Peek() - to see the first data in Queue.
        - Iterate - Loop and display the data.

using System;
using System.Collections.Generic;

public class Program
{
    public static void Main(string[] args)
    {
        Queue<string> Que = new Queue<string>();
        
        Que.Enqueue("Luffy");
        Que.Enqueue("Sanji");
        Que.Enqueue("Zoro");
        
        foreach(string result in Que){
            Console.WriteLine(result);
        }
        
        Console.WriteLine(Que.Dequeue() + "Finished one");
        
        foreach(string result in Que){
            Console.WriteLine(result);
        }
        
        Console.WriteLine("Peek the front value : " + Que.Peek());
    }
}
