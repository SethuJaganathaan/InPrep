C#

(ref and out keyword)
(ref) - Passing the variable by reference, not by the value
        Intialise the value before passing it
        
  (E.g program)
    public class Program{
      static void main(string args[]){
          int number = 10;
          Console.WriteLine("First" + number);
          ChangeNumber(ref number);
          Console.WriteLine("Second" + number);
        }
      public void ChangeNumber(int ref value){
          value = 69;
      }
    }


----------------------------------------------------------------

//Single Inheritence
 Class Inherits from a single base class
 Derived class get all accessible properties/Methods from the base class.
 A -> b

//Multilevel Inheritence
 Derived class become base class for another derived class
 A -> B -> c

//Hierarchical Inheritence
 It envolves single base class with multiple derived class.
 A -> b,c,d

//Multiple Inheritence
 C# does not allow this with classes, only with interfaces
 refer below code
 A -> b, C -> b

// Inheritence Example
using System;

//Single Inheritence
public class SCalculator{
    public double Addition(double a, double b){
        return a + b;
    }
}

public class SAdvancedCalc : SCalculator{
    public double Multiply(double a, double b){
        return a * b;
    }
}

// Multilevel Inheritence
public class MLCalculator{
    public double Addition(double a, double b){
        return a + b;
    }
}

public class MLFirstChild : MLCalculator{
    public double Multiply(double a, double b){
        return a * b;
    }
}

public class MLSecondChild : MLFirstChild{
    public double substract(double a, double b){
        return a - b;
    }
}

// Multiple Inheritence 
public interface IAdd{
    double add(double a, double b);
}

public interface IMultiply{
    double multiply(double a, double b);
}

public class FinalCalc : IAdd,IMultiply{
    public double add(double a, double b){
        return a + b;
    }
    
    public double multiply(double a, double b){
        return a * b;
    }
}

public class HelloWorld
{
    public static void Main(string[] args)
    {
        // Single Inheritence
        SAdvancedCalc result = new SAdvancedCalc();
        double mult = result.Multiply(5,4);
        double add = result.Addition(2,3);
        
        double[] final = { mult, add };
        foreach(double finalress in final){
            Console.WriteLine($"Calcultion : {finalress}");
        }
        
        // Multilevel Inheritence
        MLSecondChild mlsecond = new MLSecondChild();
        double mlres = mlsecond.Multiply(2,2);
        double mlres2 = mlsecond.substract(10,4);
        
        MLFirstChild mlfirst = new MLFirstChild();
        double mlfirstRes = mlfirst.Multiply(2,4);
        double mlfirstRes2 = mlfirst.Addition(6,5);
        
        double[] finalres = { mlres,mlres2,mlfirstRes,mlfirstRes2 };
        for(int i = 0; i < finalres.Length; i++){
            Console.WriteLine($"Result : {finalres[i]}");
        }
        
        //Multiple
        FinalCalc results = new FinalCalc();
        double aResult = results.add(4,2);
        double mResult = results.multiply(10,2);
        
        double[] finalresult = { aResult, mResult };
        for(int j = 0; j < finalresult.Length; j++){
            Console.WriteLine($"Final : {finalresult[j]}");
        }
    }
}
