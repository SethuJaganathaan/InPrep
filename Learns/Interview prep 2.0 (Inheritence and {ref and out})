Array - Merging(Using CopyTo)
 int[] arr1 = { 10, 20 };
 int[] arr2 = { 30, 40 };
 int[] merged = new int[arr1.Length + arr2.Length];

 arr1.CopyTo(merged, 0);
 arr2.CopyTo(merged, arr1.Length);
 
 
-- Bubble Sort
 for (int i = 0; i < merged.Length - 1; i++)
 {
    for (int j = 0; j < merged.Length - 1 - i; j++)
    {
        if (merged[j] > merged[j + 1])
        {
            // swap
            int temp = merged[j];
            merged[j] = merged[j + 1];
            merged[j + 1] = temp;
        }
    }
 }
